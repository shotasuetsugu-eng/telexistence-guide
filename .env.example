NODE_ENV=production
DATABASE_URL=
JWT_SECRET=
OWNER_OPEN_ID=

# Google Drive Integration
# APIキー方式（公開フォルダのみ）
GOOGLE_DRIVE_API_KEY=
# 表示したいフォルダのID（URLの /folders/XXXX の部分）
GOOGLE_DRIVE_FOLDER_ID=
# サービスアカウント方式（非公開フォルダも可）
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=

# Slack Integration
# Bot Token (xoxb-...) または User Token (xoxp-...)
SLACK_BOT_TOKEN=
