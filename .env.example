NODE_ENV=production
DATABASE_URL=
JWT_SECRET=
OWNER_OPEN_ID=

# Google Maps Integration
# サーバー側の住所検索・スポット検索用
GOOGLE_MAPS_API_KEY=
# ブラウザ側の地図表示用（HTTPリファラー制限推奨）
VITE_GOOGLE_MAPS_API_KEY=

# Google Drive Integration
# APIキー方式（公開フォルダのみ）
GOOGLE_DRIVE_API_KEY=
# 表示したいフォルダのID（URLの /folders/XXXX の部分）
GOOGLE_DRIVE_FOLDER_ID=
# サービスアカウント方式（非公開フォルダも可）
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=
